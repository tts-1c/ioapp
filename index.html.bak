<!DOCTYPE html>
<html lang="ru">
<head>
    <meta charset="UTF-8">
    <meta name="apple-mobile-web-app-capable" content="yes">
    <meta name="apple-mobile-web-app-status-bar-style" content="default">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, user-scalable=no, viewport-fit=cover">
    <title>Покупки</title>
    <style>
        :root {
            --ios-blue: #007AFF;
            --ios-red: #FF3B30;
            --ios-bg: #F2F2F7;
            --ios-card: #FFFFFF;
            --ios-separator: #C6C6C8;
        }

        body {
            font-family: -apple-system, BlinkMacSystemFont, sans-serif;
            background-color: var(--ios-bg);
            margin: 0;
            color: #000;
            -webkit-tap-highlight-color: transparent;
            user-select: none;
        }

        header {
            position: sticky;
            top: 0;
            z-index: 100;
            background: rgba(255, 255, 255, 0.8);
            backdrop-filter: blur(20px);
            -webkit-backdrop-filter: blur(20px);
            padding: 50px 16px 12px 16px;
            border-bottom: 0.5px solid var(--ios-separator);
        }

        header h1 { font-size: 34px; margin: 0; font-weight: 700; letter-spacing: -1px; }
        
        /* Заголовок внутри списка — теперь большой и жирный */
        .title-row { display: flex; align-items: center; gap: 10px; margin-bottom: 5px; }
        .inner-title { font-size: 30px; font-weight: 700; letter-spacing: -0.5px; margin: 0; flex: 1; }

        .container { padding: 16px; }

        .input-row {
            display: flex;
            align-items: center;
            gap: 10px;
            margin-bottom: 24px;
        }

        input {
            background: #E3E3E8;
            border: none;
            padding: 12px 16px;
            border-radius: 12px;
            font-size: 17px;
            outline: none;
        }

        #new-list-name, #new-item-name { flex: 3; }
        #new-item-qty { flex: 1; width: 60px; text-align: center; }

        .btn-circle {
            width: 32px; height: 32px;
            background-color: var(--ios-blue);
            border-radius: 50%;
            display: flex; align-items: center; justify-content: center;
            border: none; color: white; font-size: 24px; font-weight: 300;
            flex-shrink: 0;
        }

        .btn-back {
            color: var(--ios-blue);
            font-size: 17px;
            background: none; border: none;
            display: flex; align-items: center; padding: 0;
            margin-bottom: 10px;
        }

        .table-view {
            background: var(--ios-card);
            border-radius: 12px;
            overflow: hidden;
            margin-bottom: 30px;
        }

        .row-wrapper {
            position: relative;
            background-color: var(--ios-red);
            border-bottom: 0.5px solid var(--ios-separator);
            overflow: hidden;
        }

        .row-wrapper:last-child { border-bottom: none; }

        .table-row {
            display: flex;
            align-items: center;
            justify-content: space-between;
            padding: 14px 16px;
            background: var(--ios-card);
            position: relative;
            z-index: 2;
            transition: transform 0.3s ease-out;
			touch-action: pan-y;
        }

        .swipe-actions {
            position: absolute;
            right: 0; top: 0; bottom: 0;
            display: flex;
            z-index: 1;
        }

        .action-btn {
            width: 85px;
            display: flex; align-items: center; justify-content: center;
            color: white; font-weight: 600; font-size: 15px; border: none;
        }
        .action-edit { background-color: var(--ios-blue); }
        .action-delete { background-color: var(--ios-red); }

        .list-name { font-weight: 700; font-size: 20px; letter-spacing: -0.5px; }
        .list-date { font-size: 13px; color: #8E8E93; margin-top: 2px; }
        
        .item-text { font-size: 17px; flex: 1; text-align: left; }
        .item-qty { font-size: 17px; color: #8E8E93; margin-left: 10px; }

        .bought { background-color: #F2F2F7 !important; }
        .bought .item-text, .bought .item-qty { text-decoration: line-through; color: #8E8E93; }

        .hidden { display: none; }
    </style>
</head>
<body>

<div id="view-main">
    <header><h1>Списки</h1></header>
    <div class="container">
        <div class="input-row">
            <input type="text" id="new-list-name" placeholder="Новый список">
            <button class="btn-circle" onclick="newList()">+</button>
        </div>
        <div id="lists-container" class="table-view"></div>
    </div>
</div>

<div id="view-items" class="hidden">
    <header>
        <button class="btn-back" onclick="showMain()">‹ Назад</button>
        <div class="title-row">
            <h1 id="current-list-title" class="inner-title"></h1>
        </div>
    </header>
    <div class="container">
        <div class="input-row">
            <input type="text" id="new-item-name" placeholder="Товар">
            <input type="text" id="new-item-qty" placeholder="Кол-во">
            <button class="btn-circle" onclick="addItem()">+</button>
        </div>
        <div id="items-container" class="table-view"></div>
    </div>
</div>

<script>
    let db, currentListId = null, startX = 0, activeRow = null;

    const request = indexedDB.open("ShoppingDB", 3);
    request.onupgradeneeded = (e) => {
        db = e.target.result;
        if (!db.objectStoreNames.contains("lists")) db.createObjectStore("lists", { keyPath: "id", autoIncrement: true });
        if (!db.objectStoreNames.contains("items")) db.createObjectStore("items", { keyPath: "id", autoIncrement: true }).createIndex("listId", "listId");
    };
    request.onsuccess = (e) => { db = e.target.result; renderLists(); };

    function haptic() { if (navigator.vibrate) navigator.vibrate(15); }

	function tStart(e) {
		startX = e.touches[0].clientX; // Берем первую точку касания
		if (activeRow && activeRow !== e.currentTarget) closeSwipe();
	}

	function tMove(e) {
		let diff = startX - e.touches[0].clientX;
		
		// Если свайп идет влево (diff > 0)
		if (diff > 5) { 
			// Блокируем стандартное поведение браузера (скролл всей страницы влево/вправо)
			if (e.cancelable) e.preventDefault(); 
			
			if (diff < 200) {
				e.currentTarget.style.transform = `translateX(-${diff}px)`;
				e.currentTarget.style.transition = 'none';
			}
		}
	}

	function tEnd(e) {
		let diff = startX - e.changedTouches[0].clientX;
		let row = e.currentTarget;
		row.style.transition = 'transform 0.3s ease-out';
		
		if (diff > 80) {
			row.style.transform = `translateX(-170px)`;
			activeRow = row;
		} else {
			row.style.transform = `translateX(0)`;
			activeRow = null;
		}
	}

    function closeSwipe() {
        if (activeRow) {
            activeRow.style.transform = `translateX(0)`;
            activeRow = null;
        }
    }

    function renderLists() {
        const container = document.getElementById('lists-container');
        container.innerHTML = '';
        db.transaction("lists").objectStore("lists").getAll().onsuccess = (e) => {
            e.target.result.forEach(list => {
                const div = document.createElement('div');
                div.className = 'row-wrapper';
                div.innerHTML = `
                    <div class="swipe-actions">
                        <button class="action-btn action-edit" onclick="editList(${list.id},'${list.name}')">Правка</button>
                        <button class="action-btn action-delete" onclick="deleteList(${list.id})">Удалить</button>
                    </div>
                    <div class="table-row" ontouchstart="tStart(event)" ontouchmove="tMove(event)" ontouchend="tEnd(event)" onclick="if(!activeRow) showItems(${list.id}, '${list.name}')">
                        <div>
                            <span class="list-name">${list.name}</span>
                            <div class="list-date">${list.date}</div>
                        </div>
                    </div>`;
                container.appendChild(div);
            });
        };
    }

    function renderItems() {
        const container = document.getElementById('items-container');
        container.innerHTML = '';
        const index = db.transaction("items").objectStore("items").index("listId");
        index.getAll(IDBKeyRange.only(currentListId)).onsuccess = (e) => {
            e.target.result.forEach(item => {
                const div = document.createElement('div');
                div.className = 'row-wrapper';
                div.innerHTML = `
                    <div class="swipe-actions">
                        <button class="action-btn action-edit" onclick="editItem(${item.id},'${item.name}','${item.qty||''}')">Правка</button>
                        <button class="action-btn action-delete" onclick="deleteItem(${item.id})">Удалить</button>
                    </div>
                    <div class="table-row ${item.bought ? 'bought' : ''}" ontouchstart="tStart(event)" ontouchmove="tMove(event)" ontouchend="tEnd(event)" onclick="if(!activeRow) toggleItem(${item.id}, ${item.bought})">
                        <span class="item-text">${item.name}</span>
                        <span class="item-qty">${item.qty || ''}</span>
                    </div>`;
                container.appendChild(div);
            });
        };
    }

    document.getElementById('new-list-name').onkeypress = (e) => { if (e.key === 'Enter') newList(); };
    document.getElementById('new-item-name').onkeypress = (e) => { if (e.key === 'Enter') addItem(); };
    document.getElementById('new-item-qty').onkeypress = (e) => { if (e.key === 'Enter') addItem(); };

    function newList() {
        const input = document.getElementById('new-list-name');
        if (!input.value) return;
        const transaction = db.transaction(["lists"], "readwrite");
        transaction.objectStore("lists").add({ name: input.value, date: new Date().toLocaleDateString('ru-RU') });
        transaction.oncomplete = () => { input.value = ''; renderLists(); haptic(); input.focus(); };
    }

    function addItem() {
        const nameInput = document.getElementById('new-item-name');
        const qtyInput = document.getElementById('new-item-qty');
        if (!nameInput.value) return;
        const transaction = db.transaction(["items"], "readwrite");
        transaction.objectStore("items").add({ listId: currentListId, name: nameInput.value, qty: qtyInput.value, bought: false });
        transaction.oncomplete = () => { nameInput.value = ''; qtyInput.value = ''; renderItems(); haptic(); nameInput.focus(); };
    }

    function toggleItem(id, status) {
        haptic();
        const store = db.transaction(["items"], "readwrite").objectStore("items");
        store.get(id).onsuccess = (e) => {
            const data = e.target.result;
            data.bought = !status;
            store.put(data).onsuccess = renderItems;
        };
    }

    function editList(id, old) {
        const name = prompt("Название:", old);
        if (name) {
            const store = db.transaction(["lists"], "readwrite").objectStore("lists");
            store.get(id).onsuccess = (e) => {
                let d = e.target.result; d.name = name;
                store.put(d).onsuccess = renderLists;
            };
        }
        closeSwipe();
    }

    function editItem(id, n, q) {
        const name = prompt("Товар:", n);
        if (name === null) return closeSwipe();
        const qty = prompt("Кол-во:", q);
        const store = db.transaction(["items"], "readwrite").objectStore("items");
        store.get(id).onsuccess = (e) => {
            let d = e.target.result; d.name = name; d.qty = qty;
            store.put(d).onsuccess = renderItems;
        };
        closeSwipe();
    }

    function deleteList(id) {
        db.transaction(["lists", "items"], "readwrite").objectStore("lists").delete(id);
        renderLists(); activeRow = null; haptic();
    }

    function deleteItem(id) {
        db.transaction(["items"], "readwrite").objectStore("items").delete(id).onsuccess = renderItems;
        activeRow = null; haptic();
    }

    function showItems(id, name) {
        currentListId = id;
        document.getElementById('current-list-title').innerText = name;
        document.getElementById('view-main').classList.add('hidden');
        document.getElementById('view-items').classList.remove('hidden');
        renderItems();
        setTimeout(() => document.getElementById('new-item-name').focus(), 350);
    }

    function showMain() {
        document.getElementById('view-main').classList.remove('hidden');
        document.getElementById('view-items').classList.add('hidden');
        renderLists();
    }
</script>
</body>
</html>
